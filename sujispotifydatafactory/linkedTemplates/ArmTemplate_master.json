{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "sujispotifydatafactory"
		},
		"datalake_linked_service_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalake_linked_service'"
		},
		"sqldb_linked_service_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'sqldb_linked_service'"
		},
		"datalake_linked_service_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sujispotifystorage.dfs.core.windows.net/"
		},
		"sqldb_linked_service_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "azureprojectserversuji.database.windows.net"
		},
		"sqldb_linked_service_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sujispotifydb"
		},
		"sqldb_linked_service_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sujitha"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "sujispotifydatafactory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"datalake_linked_service_accountKey": {
						"value": "[parameters('datalake_linked_service_accountKey')]"
					},
					"sqldb_linked_service_password": {
						"value": "[parameters('sqldb_linked_service_password')]"
					},
					"datalake_linked_service_properties_typeProperties_url": {
						"value": "[parameters('datalake_linked_service_properties_typeProperties_url')]"
					},
					"sqldb_linked_service_properties_typeProperties_server": {
						"value": "[parameters('sqldb_linked_service_properties_typeProperties_server')]"
					},
					"sqldb_linked_service_properties_typeProperties_database": {
						"value": "[parameters('sqldb_linked_service_properties_typeProperties_database')]"
					},
					"sqldb_linked_service_properties_typeProperties_userName": {
						"value": "[parameters('sqldb_linked_service_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}